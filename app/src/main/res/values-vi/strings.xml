    <!-- Onboarding -->
    <string name="onboarding_title_1">Trợ lý giọng nói thông minh</string>
    <string name="onboarding_desc_1">Trợ lý dành riêng cho người cao tuổi và người khiếm thị, hỗ trợ nhiều tính năng hữu ích qua giọng nói.</string>
    <string name="onboarding_title_2">Nhận diện vật thể</string>
